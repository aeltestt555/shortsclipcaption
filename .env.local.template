# ─── Supabase ─────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...service_role_key...

# ─── Groq (Free Whisper + LLM) ────────────────────────────────
# From: console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_...

# ─── FFmpeg path ──────────────────────────────────────────────
# Windows: run "where ffmpeg" in terminal, paste result below
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# Mac/Linux: run "which ffmpeg", paste result below
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# Replit: always this path (set in Replit Secrets, not here)
# FFMPEG_PATH=/usr/bin/ffmpeg

# ─── App URL ──────────────────────────────────────────────────
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Replit: https://your-repl-name.your-username.repl.co
# Vercel: https://your-app.vercel.app
